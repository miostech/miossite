# ==========================================================================
# Mios Tech - Exemplo de variaveis de ambiente
# Copie para .env.local e preencha os valores.
# ==========================================================================

# --- Resend (newsletter, notificacao de blog e leads do portfolio) ---
# Chave da API do Resend (https://resend.com/api-keys)
RESEND_API_KEY=

# ID da audiencia do Resend (https://resend.com/audiences)
# Usada para inscritos da newsletter e contatos do portfolio.
RESEND_AUDIENCE_ID=

# Remetente verificado no Resend (ex.: "Mios Tech <hello@mios.pt>")
# Usado nos e-mails da newsletter e na notificacao de leads do portfolio.
NEWSLETTER_FROM=

# --- Leads do portfolio ---
# Para onde enviar os leads capturados no gate do portfolio.
# Se vazio, usa CONTACT_TO e, por fim, hello@mios.pt.
PORTFOLIO_LEADS_TO=

# E-mail de contato geral (fallback para os leads do portfolio).
CONTACT_TO=

# --- Geral ---
# URL publica do site (usada pelo script de notificacao de novos posts).
SITE_URL=https://www.mios.pt
